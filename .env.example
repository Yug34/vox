# Discord Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application ID (same as Bot's application ID)
CLIENT_ID=your_application_id_here

# Optional: For guild-specific command registration during development (instant updates)
# GUILD_ID=your_guild_id_here

# Command prefix for text commands (default: "!!")
# COMMAND_PREFIX=!!

# Optional: Customize trigger channel name (default: "Create Your Own VC")
# TRIGGER_CHANNEL_NAME=Create Your Own VC

# Optional: Delay before deleting empty channels in ms (default: 5000)
# CLEANUP_DELAY_MS=5000

# Redis for persistent state (channel ownership, votekick, cleanup scheduling).
# When set, the bot uses Redis instead of in-memory storage for horizontal scaling.
# Examples: redis://localhost:6379 or redis://redis:6379 (Docker)
# REDIS_URL=redis://localhost:6379

# Sharding for horizontal scaling (Astro-style). Requires REDIS_URL.
# SHARD_COUNT=4
# SHARD_IDS=0,1
