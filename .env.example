# Discord Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application ID (same as Bot's application ID)
CLIENT_ID=your_application_id_here

# Optional: For guild-specific command registration during development (instant updates)
# GUILD_ID=your_guild_id_here

# Command prefix for text commands (default: "!!")
# COMMAND_PREFIX=!!

# Optional: Customize trigger channel name (default: "Create Your Own VC")
# TRIGGER_CHANNEL_NAME=Create Your Own VC

# Optional: Delay before deleting empty channels in ms (default: 5000)
# CLEANUP_DELAY_MS=5000
