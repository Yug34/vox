{
  "name": "discord-temp-vc-bot",
  "version": "1.0.0",
  "description": "Discord bot that creates temporary voice channels with lock/unlock and selective user permitting",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["discord", "bot", "voice-channel"],
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  }
}
